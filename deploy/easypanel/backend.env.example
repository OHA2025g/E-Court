# Easypanel → ecourt → app → backend
# Public URL: https://ecourt.demoapi.agrayianailabs.com

# MongoDB — Easypanel internal host: ecourt_ecourtdb
# Paste your panel URI and append database + authSource, e.g.:
# MONGO_URL=mongodb://mongo:PASSWORD@ecourt_ecourtdb:27017/pmis_ecourts?authSource=admin&tls=false
MONGO_URL=mongodb://mongo:PASSWORD@ecourt_ecourtdb:27017/pmis_ecourts?authSource=admin&tls=false
DB_NAME=pmis_ecourts

# Redis (optional — leave empty if no Redis service)
REDIS_URL=
REQUIRE_REDIS=false

# CORS — must match frontend public URL exactly (HTTPS, no trailing slash)
CORS_ORIGINS=https://ecourt.demo.agrayianailabs.com

# Security
JWT_SECRET=REPLACE_WITH_openssl_rand_base64_48
COOKIE_SECURE=true
APP_ENV=development
JWT_STRICT=false
TRUST_PROXY_HEADERS=true

# Demo accounts (change before go-live)
ADMIN_EMAIL=admin@pmis.gov.in
ADMIN_PASSWORD=Admin@PMIS2026
CPC_DEMO_EMAIL=cpc.allahabad@pmis.gov.in
CPC_DEMO_PASSWORD=Cpc@PMIS2026
VIEWER_DEMO_EMAIL=viewer@pmis.gov.in
VIEWER_DEMO_PASSWORD=View@PMIS2026
TASK_MEMBER_EMAIL=member@pmis.gov.in
TASK_MEMBER_PASSWORD=Member@PMIS2026

APP_NAME=ecourts-pmis
DASHBOARD_REQUIRE_APPROVAL=true
ADMIN_IP_ALLOWLIST_ENABLED=false

# Easypanel service settings
# - Source path: backend/
# - Dockerfile: backend/Dockerfile
# - Container port: 8001
# - Domain: ecourt.demoapi.agrayianailabs.com
