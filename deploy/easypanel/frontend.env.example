# Easypanel → ecourt → app → frontend
# Public URL: https://ecourt.demo.agrayianailabs.com

# Build argument (Docker build — required)
REACT_APP_BACKEND_URL=https://ecourt.demoapi.agrayianailabs.com
REACT_APP_SHOW_DEMO=true

# Runtime environment (container — required for CSP fix)
CSP_API_ORIGIN=https://ecourt.demoapi.agrayianailabs.com
REACT_APP_BACKEND_URL=https://ecourt.demoapi.agrayianailabs.com

# Easypanel service settings
# - Source path: frontend/
# - Dockerfile: frontend/Dockerfile
# - Container port: 80
# - Domain: ecourt.demo.agrayianailabs.com
